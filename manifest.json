{
  "manifest_version": 3,
  "name": "AI Writing Assistant",
  "version": "1.0",
  "description": "A lightweight AI writing assistant that rephrases selected text with a modern glassmorphism UI.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "AI Writing Assistant"
  }
}
